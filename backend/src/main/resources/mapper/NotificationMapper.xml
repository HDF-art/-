<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agri.mapper.NotificationMapper">

    <select id="selectUserNotificationsPage" resultType="com.agri.dto.NotificationDTO">
        SELECT n.*, u.username as senderName
        FROM notification n
        LEFT JOIN user u ON n.sender_id = u.id
        ${ew.customSqlSegment}
    </select>

</mapper>
