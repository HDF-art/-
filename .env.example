# 农业大数据联合建模平台 - 环境变量配置
# 请复制此文件为 .env 并填写实际值

# 数据库配置
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT配置 (请使用至少32字符的随机字符串)
JWT_SECRET=your_secure_jwt_secret_key_at_least_32_characters

# 邮件服务配置
MAIL_USERNAME=your_email@yeah.net
MAIL_PASSWORD=your_email_password

# Z.ai API配置
ZAI_API_KEY=your_zai_api_key

# 可选配置
# MODEL_SERVICE_URL=http://localhost:5000/api/crop-disease
# MODEL_SAVE_PATH=./models
# UPLOAD_IMAGE_PATH=./upload/images
# UPLOAD_MODEL_PATH=./upload/models
